                    "dest" : "_deps/sdl_mixer_deps/vorbis",
                    "strip-components" : 1
                },
                {
                    "type" : "archive",
                    "url" : "https://github.com/libsdl-org/opus/archive/123a9faf5598ceef6fcb6d44bbadc4f9469945a6.tar.gz",
                    "sha256" : "745eac7ec7aac30162c2e5c921dc979ec961174ee7e19d0ba377664242b9d8e4",
                    "dest" : "_deps/sdl_mixer_deps/opus",
                    "strip-components" : 1
                },
                {
                    "type" : "archive",
                    "url" : "https://github.com/libsdl-org/opusfile/archive/d820a66af7ba7fdda346b5b439baca9a2f04dd7f.tar.gz",
                    "sha256" : "4c80a2351c6bd48c939cf0fe357ee9f65e888742386ea1f7653a4abb32fceb93",
